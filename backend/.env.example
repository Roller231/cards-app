# Database (for docker use host=db)
DATABASE_URL=mysql+aiomysql://cards_user:change-db-password@db:3306/cards_app

# JWT
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Aifory parent account credentials
AIFORY_BASE_URL=https://srv.aifory.pro/lk
AIFORY_EMAIL=
AIFORY_PASSWORD=
AIFORY_PIN=
AIFORY_TOTP_SECRET=

# Commissions
ONLINE_ISSUE_FEE_USD=1
ONLINE_TOPUP_MARKUP_PERCENT=5
ONLINE_PLUS_ISSUE_FEE_USD=5
ONLINE_PLUS_TOPUP_MARKUP_PERCENT=10
ISSUE_APPLY_TOPUP_MARKUP=false
ONLINE_CARD_VALIDITY_TEXT=1 год
ONLINE_PLUS_CARD_VALIDITY_TEXT=1 год
ONLINE_OPERATION_FEE_USD=0.4
ONLINE_PLUS_OPERATION_FEE_USD=0.4

# Admin auth
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-admin-password

# Telegram bot
TELEGRAM_BOT_TOKEN=

# Public base URL for OAuth callbacks (required behind reverse proxy)
PUBLIC_BASE_URL=https://prontopay.pro

# Gmail API OAuth2 for Apple Pay codes
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# ABCEX
ABCEX_API_KEY=
ABCEX_CRYPTO_PAYMENT_EXPIRY_MINUTES=30
